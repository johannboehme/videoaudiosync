{
  "name": "tk-1-frontend",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run copy-assets && npm run wasm:build && tsc -b && vite build",
    "preview": "vite preview",
    "copy-assets": "node scripts/copy-runtime-assets.mjs",
    "postinstall": "node scripts/copy-runtime-assets.mjs",
    "wasm:build": "cd wasm/sync-core && wasm-pack build --target web --out-dir pkg --release",
    "wasm:test": "cd wasm/sync-core && cargo test",
    "test": "vitest run --project=unit",
    "test:watch": "vitest --project=unit",
    "test:browser": "vitest run --project=browser",
    "test:all": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/core-mt": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "fft.js": "^4.0.4",
    "framer-motion": "^12.38.0",
    "idb": "^8.0.3",
    "mp4-muxer": "^5.2.2",
    "mp4box": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/browser": "^2.1.9",
    "@webgpu/types": "^0.1.69",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "playwright": "^1.59.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.4"
  }
}
